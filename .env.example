# Public origin where this app is deployed. Short links are shown and resolved
# at {NEXT_PUBLIC_SITE_URL}/{business}/{code}.
#   Local dev:   http://localhost:3000
#   Production:  https://fta-short.link  (your custom domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Hardcoded dashboard password (the only "auth")
APP_PASSWORD=change-me

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
# Leave the variables below BLANK for local development: data is stored in a
# local JSON file at ./.data/db.json (zero setup).
#
# In production (Vercel), add the free "Upstash Redis" integration from the
# Vercel Marketplace. It injects these automatically and the app will use it
# instead of the file store. (KV_REST_API_URL / KV_REST_API_TOKEN also work.)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
