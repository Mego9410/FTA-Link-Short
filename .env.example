# Public origin where this app is deployed (used to build the working short link).
# Local dev example: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# The "pretty" brand domain shown in the displayed short URL: www.{business}.{BRAND_DOMAIN}/{code}
NEXT_PUBLIC_BRAND_DOMAIN=myURL.com

# Hardcoded dashboard password (the only "auth")
APP_PASSWORD=change-me

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
# Leave the variables below BLANK for local development: data is stored in a
# local JSON file at ./.data/db.json (zero setup).
#
# In production (Vercel), add the "Upstash Redis" integration from the Vercel
# Marketplace. It injects these automatically and the app will use it instead
# of the file store. (KV_REST_API_URL / KV_REST_API_TOKEN are also accepted.)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
